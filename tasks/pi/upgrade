#!/usr/bin/env bash
#MISE description="Upgrade little-coder from vendor copy and rebuild"
set -euo pipefail

PI_IMAGE="pi-less-yolo:latest"
VENDOR_DIR="${MISE_TASK_DIR}/../../vendor/little-coder"
DOCKER_CMD="${PI_CONTAINER_RUNTIME:-docker}"

"${DOCKER_CMD}" image inspect "${PI_IMAGE}" > /dev/null 2>&1 || {
  echo "error: image not found — run: mise run pi:build" >&2
  exit 1
}

if [[ ! -d "${VENDOR_DIR}" ]] || [[ ! -f "${VENDOR_DIR}/package.json" ]]; then
  echo "error: vendor/little-coder/ not found" >&2
  exit 1
fi

CURRENT=$(node -e "console.log(require('${VENDOR_DIR}/package.json').version)" 2>/dev/null || echo "unknown")
LATEST=$("${DOCKER_CMD}" run --rm --entrypoint npm "${PI_IMAGE}" view little-coder version 2>/dev/null || echo "unknown")

echo "Vendor version: ${CURRENT}"
echo "Latest on npm:  ${LATEST}"
echo ""
echo "To upgrade, update your local fork:"
echo "  cd vendor/little-coder && git pull"
echo "Then rebuild: mise run pi:build"
echo ""

# Always rebuild since we're using a local copy
mise run pi:build
