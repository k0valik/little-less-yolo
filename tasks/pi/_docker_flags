# Builds DOCKER_FLAGS for pi container tasks. Source this file; do not execute directly.
# Usage: source "$(dirname "$0")/_docker_flags"

PI_IMAGE="pi-less-yolo:latest"

# PI_CONTAINER_RUNTIME overrides; otherwise detect podman via version output or binary path.
# || true: some docker-as-podman shims exit non-zero, which would abort under pipefail.
# readlink: when podman is symlinked as "docker", it reports "docker version X" not "podman version X".
if [[ -n "${PI_CONTAINER_RUNTIME:-}" ]]; then
  DOCKER_CMD="${PI_CONTAINER_RUNTIME}"
else
  DOCKER_CMD="docker"
  detected_version=$(docker --version 2>&1 || true)
  docker_realpath=$(readlink -f "$(command -v docker || true)" 2>/dev/null || true)
  if [[ "${detected_version}" == *podman* ]] || [[ "${docker_realpath}" == *podman* ]]; then
    DOCKER_CMD="podman"
  fi
fi

"${DOCKER_CMD}" image inspect "${PI_IMAGE}" > /dev/null 2>&1 || mise run pi:build

# Auto-source .env from the repo root (all pi-less-yolo + little-coder vars).
# Create .env from .env.example in the repo root and uncomment what you need.
REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
if [ -f "${REPO_ROOT}/.env" ]; then
  set -a
  source "${REPO_ROOT}/.env"
  set +a
fi

# LC_AGENT_DIR: the persistent little-coder config directory on the host.
# On first run it is seeded with ALL bundled content (extensions, settings,
# skills, models.json, AGENTS.md) so you can edit ANYTHING from the host.
# On subsequent runs the bind mount overwrites the container copy, so the
# user's edits persist.
LC_AGENT_DIR="${HOME}/.pi/agent-little-coder"
mkdir -p "${LC_AGENT_DIR}"

# Seed from bundled content only if the directory is empty (first run).
# The fork lives at vendor/little-coder/ inside this repo.
if [ -z "$(ls -A "${LC_AGENT_DIR}" 2>/dev/null)" ]; then
  BUNDLED_LC_DIR="$(cd "$(dirname "$0")/../../vendor/little-coder" && pwd)"
  BUNDLED_PI_DIR="${BUNDLED_LC_DIR}/.pi"
  if [ -d "${BUNDLED_PI_DIR}" ]; then
    # 1. .pi/ (extensions + settings.json)
    cp -a "${BUNDLED_PI_DIR}/." "${LC_AGENT_DIR}/"
    # 2. models.json (package root, not in .pi/)
    if [ -f "${BUNDLED_LC_DIR}/models.json" ]; then
      cp "${BUNDLED_LC_DIR}/models.json" "${LC_AGENT_DIR}/"
    fi
    # 3. skills/ (loaded at runtime by skill-inject/knowledge-inject)
    if [ -d "${BUNDLED_LC_DIR}/skills" ]; then
      cp -a "${BUNDLED_LC_DIR}/skills/." "${LC_AGENT_DIR}/skills/"
    fi
    # 4. AGENTS.md (system prompt, checked by launcher before pkgRoot version)
    if [ -f "${BUNDLED_LC_DIR}/AGENTS.md" ]; then
      cp "${BUNDLED_LC_DIR}/AGENTS.md" "${LC_AGENT_DIR}/"
    fi
    echo "[pi] seeded ${LC_AGENT_DIR} from bundled content (extensions, skills, models, AGENTS.md)"
  else
    echo "[pi] warning: vendor/little-coder/ not found — ${LC_AGENT_DIR} is empty" >&2
  fi
fi

# Permissions:
#   --user $(id -u):$(id -g)   files created in /workspace are owned by the
#                               calling user on the host, not root.
#   --cap-drop=ALL             drop all Linux capabilities; pi needs none.
#   --no-new-privileges        prevent setuid binaries from gaining privileges.
#
# Mounts:
#   $(pwd):$(pwd)              current directory, mounted at its real host path.
#   ~/.pi/agent-little-coder:/pi-agent   little-coder's own config dir
#                               (settings, sessions, models, extensions).
#                               The host's global ~/.pi/agent is never
#                               mounted, never touched, never mixed.
DOCKER_FLAGS=(
  "--rm"
  "--user" "$(id -u):$(id -g)"
  "--cap-drop=ALL"
  "--security-opt=no-new-privileges"
  "--ipc=none"
  "--volume" "$(pwd):$(pwd)${_PI_WORKDIR_RO:+:ro}"  # :ro set by pi:readonly
  "--volume" "${LC_AGENT_DIR}:/pi-agent"
  "--workdir" "$(pwd)"
  "--env" "PI_CODING_AGENT_DIR=/pi-agent"
  "--env" "TERM=${TERM:-xterm-256color}"
  "--env" "COLORTERM=${COLORTERM:-truecolor}"
)

# Podman-specific: use --userns=keep-id to properly map the user namespace
# and avoid "crun: chown `/dev/pts/0`: Invalid argument" errors.
if [[ "${DOCKER_CMD}" == "podman" ]]; then
  DOCKER_FLAGS+=("--userns=keep-id")
fi

# Forward pi-related env vars and API keys if set on the host.
# Auth file (~/.pi/agent-little-coder/auth.json) takes priority over these if present.
PI_ENV_VARS=(
  PI_SKIP_VERSION_CHECK
  PI_CACHE_RETENTION
  PI_PACKAGE_DIR
  VISUAL
  EDITOR
  # Cloud provider API keys
  ANTHROPIC_API_KEY
  AZURE_OPENAI_API_KEY
  OPENAI_API_KEY
  GEMINI_API_KEY
  MISTRAL_API_KEY
  GROQ_API_KEY
  CEREBRAS_API_KEY
  XAI_API_KEY
  OPENROUTER_API_KEY
  AI_GATEWAY_API_KEY
  ZAI_API_KEY
  OPENCODE_API_KEY
  KIMI_API_KEY
  MINIMAX_API_KEY
  MINIMAX_CN_API_KEY
  # Local provider API keys (dummy value like "noop" required even for local servers)
  LLAMACPP_API_KEY
  OLLAMA_API_KEY
  LMSTUDIO_API_KEY
  # Local provider URL overrides
  LLAMACPP_BASE_URL
  OLLAMA_BASE_URL
  LMSTUDIO_BASE_URL
  # little-coder bash gate
  LITTLE_CODER_PERMISSION_MODE
  LITTLE_CODER_BASH_ALLOW
  LITTLE_CODER_MODELS_FILE
)
for var in "${PI_ENV_VARS[@]}"; do
  [ -n "${!var:-}" ] && DOCKER_FLAGS+=("--env" "$var=${!var}")
done

# Git identity: mount ~/.gitconfig read-only. Opt out with PI_NO_GITCONFIG=1.
# Credential helpers (e.g. osxkeychain) are unavailable; git falls back to prompting.
if [[ -z "${PI_NO_GITCONFIG:-}" && -f "${HOME}/.gitconfig" ]]; then
  DOCKER_FLAGS+=("--volume" "${HOME}/.gitconfig:/home/piuser/.gitconfig:ro")
fi

# Resource limits. Opt in by setting any of PI_MEMORY, PI_CPUS, or PI_PIDS_LIMIT.
# Examples: PI_MEMORY=4g PI_CPUS=2 PI_PIDS_LIMIT=512
[[ -n "${PI_MEMORY:-}" ]]     && DOCKER_FLAGS+=("--memory" "${PI_MEMORY}")
[[ -n "${PI_CPUS:-}" ]]       && DOCKER_FLAGS+=("--cpus" "${PI_CPUS}")
[[ -n "${PI_PIDS_LIMIT:-}" ]] && DOCKER_FLAGS+=("--pids-limit" "${PI_PIDS_LIMIT}")

# PI_LOCAL_MODELS=1: share the host network namespace so local model servers
# (Ollama, LM Studio, vLLM) are reachable at their native localhost URLs.
# Security: all host ports become reachable. macOS: uses the Docker Desktop VM
# network — localhost on the Mac is not reachable; use host.docker.internal.
if [[ -n "${PI_LOCAL_MODELS:-}" ]]; then
  DOCKER_FLAGS+=("--network=host")
fi

# SSH agent forwarding. Opt in by setting PI_SSH_AGENT=1.
# Also mounts ~/.ssh/known_hosts and ~/.ssh/config read-only.
# Security: a compromised container can authenticate as you to any server your
# agent has loaded. If ~/.ssh/config contains ForwardAgent yes, that forwarding
# cascades to any server the container connects to. Review loaded keys with
# `ssh-add -l` before enabling.
if [[ -n "${PI_SSH_AGENT:-}" ]]; then
  if [[ -f "${HOME}/.ssh/known_hosts" ]]; then
    DOCKER_FLAGS+=("--volume" "${HOME}/.ssh/known_hosts:/home/piuser/.ssh/known_hosts:ro")
  fi
  if [[ -f "${HOME}/.ssh/config" ]]; then
    DOCKER_FLAGS+=("--volume" "${HOME}/.ssh/config:/home/piuser/.ssh/config:ro")
  fi

  if [[ "$(uname -s)" == "Darwin" ]] && [[ "${DOCKER_CMD}" == "docker" ]]; then
    # Docker Desktop creates the socket root:root 660; add GID 0 so the
    # non-root user can access it. --cap-drop=ALL limits the exposure.
    DOCKER_FLAGS+=(
      "--mount" "type=bind,src=/run/host-services/ssh-auth.sock,target=/run/host-services/ssh-auth.sock"
      "--env" "SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock"
      "--group-add" "0"
    )
  elif [[ -S "${SSH_AUTH_SOCK:-}" ]]; then
    DOCKER_FLAGS+=(
      "--volume" "${SSH_AUTH_SOCK:-}:${SSH_AUTH_SOCK:-}"
      "--env" "SSH_AUTH_SOCK=${SSH_AUTH_SOCK:-}"
    )
  else
    echo "warning: PI_SSH_AGENT=1 but SSH_AUTH_SOCK is not set or is not a socket — SSH agent forwarding disabled" >&2
  fi
fi
