#!/usr/bin/env bash
#MISE description="Remove pi global tasks from mise"
set -euo pipefail

CONF_FILE="${XDG_CONFIG_HOME:-${HOME}/.config}/mise/conf.d/pi-less-yolo.toml"

if [[ ! -f "${CONF_FILE}" ]]; then
  echo "Nothing to uninstall (${CONF_FILE} not found)."
  exit 0
fi

rm "${CONF_FILE}"

echo ""
echo "Removed ${CONF_FILE}."
echo ""
echo "The Docker image (pi-less-yolo:latest) and little-coder config (~/.pi/agent-little-coder) were not touched."
echo "To remove the image:  ${PI_CONTAINER_RUNTIME:-docker} rmi pi-less-yolo:latest"
echo "To remove little-coder config:  rm -rf ~/.pi/agent-little-coder"
echo ""
