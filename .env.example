# ═══════════════════════════════════════════════════════════════════════════
# pi-less-yolo + little-coder Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env in the same directory and uncomment what you need.
# All pi tasks (mise run pi, pi:shell, pi:health, etc.) auto-source .env.
#
#   cp .env.example .env
#   # edit .env → uncomment your settings
#   mise run pi
#
# ── Quick example for local models (WSL2 + Docker Desktop) ───────────────
#   cp .env.example .env
#   # Uncomment these lines in .env:
#     PI_LOCAL_MODELS=1
#     LLAMACPP_API_KEY=noop
#     OLLAMA_API_KEY=noop
#   mise run pi -- --model llamacpp/qwen3.6-35b-a3b


# ── pi-less-yolo runtime options ─────────────────────────────────────────

# Enable --network=host so local model servers (llama.cpp, Ollama, LM Studio)
# on your host are reachable at localhost from inside the container.
# WSL2 + Docker Desktop + mirrored networking: localhost reaches WSL2 directly.
# macOS Docker Desktop: use host.docker.internal in models.json instead.
# PI_LOCAL_MODELS=1

# SSH agent forwarding: mount SSH_AUTH_SOCK + ~/.ssh/* into the container.
# Required for SSH-based git remotes (git clone git@github.com:...).
# PI_SSH_AGENT=1

# Suppress the ~/.gitconfig read-only mount (enabled by default).
# PI_NO_GITCONFIG=1

# Suppress the "running inside a Docker container" system-prompt hint.
# PI_NO_CONTAINER_PROMPT=1

# Container runtime override (auto-detects podman via docker --version).
# PI_CONTAINER_RUNTIME=podman

# Resource limits (unset = no limit).
# PI_MEMORY=4g
# PI_CPUS=2
# PI_PIDS_LIMIT=512


# ── little-coder launcher options ────────────────────────────────────────

# Bash permission mode: auto (default) / accept-all / manual.
#   auto:        block any bash command not on the safe-prefix whitelist
#   accept-all:  skip the gate entirely (all bash calls pass)
# LITTLE_CODER_PERMISSION_MODE=accept-all

# Extra bash allow-prefixes merged with the built-in whitelist.
# Separate multiple with commas. Trailing whitespace is meaningful.
# LITTLE_CODER_BASH_ALLOW="make ,docker compose ps"

# Explicit path to a custom models.json override (checked before all others).
# LITTLE_CODER_MODELS_FILE=/home/me/my-models.json


# ── Cloud provider API keys (set the ones you use) ───────────────────────

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# AZURE_OPENAI_API_KEY=...
# GEMINI_API_KEY=...
# MISTRAL_API_KEY=...
# GROQ_API_KEY=...
# CEREBRAS_API_KEY=...
# XAI_API_KEY=...
# OPENROUTER_API_KEY=...
# AI_GATEWAY_API_KEY=...
# ZAI_API_KEY=...
# OPENCODE_API_KEY=...
# KIMI_API_KEY=...
# MINIMAX_API_KEY=...
# MINIMAX_CN_API_KEY=...


# ── Local provider setup ─────────────────────────────────────────────────
# These are only needed when running local models (llama.cpp / Ollama / LM Studio).
# The API keys can be any non-empty string — local servers ignore them but pi
# requires a value. Set PI_LOCAL_MODELS=1 above for host-network access.

# Local provider API keys (REQUIRED — set to "noop" or any non-empty string)
# LLAMACPP_API_KEY=noop
# OLLAMA_API_KEY=noop
# LMSTUDIO_API_KEY=noop

# Local provider base URL overrides (optional — defaults below)
# LLAMACPP_BASE_URL=http://127.0.0.1:8888/v1
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
